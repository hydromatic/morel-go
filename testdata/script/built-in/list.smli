 *
 * Unit tests for the built-in `List` structure, defined
 * by the Standard ML Basis Library.
 *)
Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

(*) val null : 'a list -> bool
List.null;
> val it = fn : 'a list -> bool
List.null [];
> val it = true : bool
List.null [1];
> val it = false : bool

(*) val length : 'a list -> int
List.length;
> val it = fn : 'a list -> int
List.length [];
> val it = 0 : int
List.length [1,2];
> val it = 2 : int

(*) val @ : 'a list * 'a list -> 'a list
List.`@`;
> val it = fn : 'a list * 'a list -> 'a list
List.`@` ([1], [2, 3]);
> val it = [1,2,3] : int list
List.`@` ([1], []);
> val it = [1] : int list
List.`@` ([], [2]);
> val it = [2] : int list
List.`@` ([], []);
> val it = [] : 'a list

[1] @ [2, 3];
> val it = [1,2,3] : int list
[] @ [];
> val it = [] : 'a list

(*) val hd : 'a list -> 'a
List.hd;
> val it = fn : 'a list -> 'a
List.hd [1,2,3];
> val it = 1 : int
List.hd [];
> uncaught exception Empty
>   raised at: stdIn:1.1-1.11

(*) val tl : 'a list -> 'a list
List.tl;
> val it = fn : 'a list -> 'a list
List.tl [1,2,3];
> val it = [2,3] : int list
List.tl [];
> uncaught exception Empty
>   raised at: stdIn:1.1-1.11

(*) val rev : 'a list -> 'a list
List.rev;
> val it = fn : 'a list -> 'a list
List.rev [1,2,3];
> val it = [3,2,1] : int list
List.rev [2,1];
> val it = [1,2] : int list
List.rev [1];
> val it = [1] : int list
List.rev [];
> val it = [] : 'a list

(*) val map : ('a -> 'b) -> 'a list -> 'b list
List.map;
> val it = fn : ('a -> 'b) -> 'a list -> 'b list
List.map (fn x => x + 1) [1,2,3];
> val it = [2,3,4] : int list
List.map (fn x => x + 1) [];
> val it = [] : int list

(*) map is alias for List.map
map;
> val it = fn : ('a -> 'b) -> 'a list -> 'b list
map (fn x => x) [];
> val it = [] : 'a list

(*) End list.smli
