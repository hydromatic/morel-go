Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

(* Descending:
     datatype descending = DESC of 'a
*)
DESC;
> val it = fn : 'a -> 'a descending
DESC "a";
> val it = DESC "a" : string descending
DESC (DESC "a");
> val it = DESC (DESC "a") : string descending descending

(*) The "compare" function.
Relational.compare;
> val it = fn : 'a * 'a -> order
(*) Option compares with NONE less than any value.
Relational.compare (SOME 1, SOME "a");
> stdIn:1.1-1.38 Error: Cannot deduce type: conflict: int vs string
>   raised at: stdIn:1.1-1.38
(* 'word' compares as unsigned: a word with the high bit set is the largest
   value, and 'order'/'order DESC' sort accordingly. *)

(*) End relational.smli
