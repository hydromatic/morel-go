 *
 * Unit tests for the built-in `Range` structure.
 *)
Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

CLOSED (3, 7) : int range;
> val it = CLOSED (3,7) : int range

(*) Range.contains: prefix and postfix.
Range.contains (CLOSED (3, 7)) 5;
> val it = true : bool

(*) Range.continuousSetOf normalizes overlapping ranges.
Range.continuousSetOf [CLOSED (5, 10), CLOSED (1, 3), CLOSED (3, 6)];
> val it = CONTINUOUS_SET [CLOSED (1,10)] : int continuous_set

(*) Range.discreteSetOf normalizes overlapping and adjacent ranges.
Range.discreteSetOf [CLOSED (5, 10), CLOSED (1, 3), CLOSED (3, 6)];
> val it = DISCRETE_SET [CLOSED (1,10)] : int discrete_set

(* Range.flatten concatenates ranges in input order, preserving
 * duplicates. *)
Range.flatten [CLOSED (0, 3), POINT 10, CLOSED (2, 5)];
> val it = [0,1,2,3,10,2,3,4,5] : int list

(*) End range.smli
